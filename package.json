{
  "name": "family-tree",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "generate": "prisma generate",
    "check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "gen": "wrangler types",
    "db:push": "wrangler d1 execute family-tree",
    "db:generate": "prisma generate",
    "db:migrate": "wrangler d1 migrations apply family-tree",
    "db:studio": "prisma studio",
    "db:seed-d1": "wrangler d1 execute family-tree --file=./seed.sql",
    "db:seed": "DATABASE_URL=\"file:$(find .wrangler -path '*miniflare-D1DatabaseObject/*.sqlite' ! -name 'metadata.sqlite' | head -n 1)\" tsx prisma/seed.ts",
    "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output prisma/schema.prisma --yes",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.18.2",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.17.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "better-auth": "~1.6.15",
    "better-sqlite3": "^12.10.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "prisma": "^7.8.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^8.0.16",
    "wrangler": "^4.99.0"
  },
  "packageManager": "pnpm@11.5.2"
}

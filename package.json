{
  "name": "family-tree",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "generate": "prisma generate",
    "check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "gen": "wrangler types",
    "db:push": "wrangler d1 execute family-tree",
    "db:generate": "prisma generate",
    "db:migrate": "wrangler d1 migrations apply family-tree",
    "db:studio": "prisma studio",
    "db:seed-d1": "wrangler d1 execute family-tree --file=./seed.sql",
    "db:seed": "DATABASE_URL=\"file:$(find .wrangler -path '*miniflare-D1DatabaseObject/*.sqlite' ! -name 'metadata.sqlite' | head -n 1)\" tsx prisma/seed.ts",
    "auth:schema": "better-auth generate --config src/lib/server/auth.ts --output prisma/schema.prisma --yes",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write ."
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "~1.4.21",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "^2.15.2",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.16.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24",
    "better-auth": "~1.4.21",
    "better-sqlite3": "^12.10.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "prisma": "^7.8.0",
    "shadcn-svelte": "^1.2.7",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^8.0.7",
    "wrangler": "^4.98.0"
  },
  "packageManager": "pnpm@11.5.2"
}
